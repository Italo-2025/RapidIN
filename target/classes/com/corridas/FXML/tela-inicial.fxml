<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.rapidIN.controller.TelaInicialController"
      styleClass="tela-inicial"
      alignment="CENTER"
      spacing="20"
      prefWidth="900" prefHeight="660">

    <Label text="RapidIN" styleClass="titulo-principal"/>
    <Label text="Plataforma de Corridas" styleClass="subtitulo"/>

    <VBox styleClass="card-login" spacing="14" alignment="CENTER">

        <Label text="Entrar na sua conta" styleClass="titulo-secao"/>

        <Label text="E-mail" styleClass="label-campo"/>
        <TextField fx:id="campoEmail"
                   promptText="seu@email.com"
                   styleClass="campo-texto"/>

        <Label text="Senha" styleClass="label-campo"/>
        <PasswordField fx:id="campoSenha"
                       promptText="••••••••"
                       styleClass="campo-texto"/>

        <Button text="Entrar"
                onAction="#fazerLogin"
                styleClass="botao-primario"/>

        <Label fx:id="mensagemErro"
               styleClass="mensagem-erro"
               visible="false"/>

        <Label text="Nao tem conta? Cadastre-se aqui"
               styleClass="link-texto"
               onMouseClicked="#irParaCadastro"/>

    </VBox>

    <Label text="[MODO TESTE] Senha de todos: 123456  |  joao@email.com (passageiro M)  |  maria@email.com (passageiro F)  |  carlos@email.com (motorista M)  |  ana@email.com (motorista F)"
           styleClass="dica-teste"
           wrapText="true"
           maxWidth="700"/>

</VBox>
